# ============================================================
# Momentum Monster Scanner — Environment Variables
# Copy this file to .env.local for local development
# ============================================================

# Set to "true" to use mock/simulated data instead of live Yahoo Finance.
# Recommended for:
#   - Local dev (avoids hitting Yahoo rate limits)
#   - Vercel preview branches
#   - Demos / screenshots
# Set to "false" (or remove) for production live-data mode.
NEXT_PUBLIC_MOCK_DATA=true

# ============================================================
# Optional: Future data provider keys
# (Yahoo Finance is unofficial and rate-limited. For production
#  trading-grade data, replace lib/data/yahoo.ts with one of:)
# ============================================================

# Polygon.io — best for full symbol universe + real-time float/SI data
# POLYGON_API_KEY=your_polygon_key_here

# Finnhub — good for real-time quotes + basic fundamentals
# FINNHUB_API_KEY=your_finnhub_key_here

# Alpaca Market Data — real-time bars + screener
# ALPACA_API_KEY=your_alpaca_key
# ALPACA_API_SECRET=your_alpaca_secret

# ============================================================
# Optional: Caching layer (strongly recommended for production)
# ============================================================

# Vercel KV (Upstash Redis) — enables cross-instance caching so
# multiple Vercel function instances share the same scan result
# KV_REST_API_URL=https://xxx.upstash.io
# KV_REST_API_TOKEN=xxx

# ============================================================
# App settings
# ============================================================

# How often (ms) the frontend polls for new data (default: 60000 = 1 min)
# NEXT_PUBLIC_REFRESH_INTERVAL_MS=60000
